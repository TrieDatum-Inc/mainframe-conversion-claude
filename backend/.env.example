# CardDemo Backend Environment Variables
# Copy this file to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://carddemo:carddemo@localhost:5432/carddemo
DATABASE_URL_SYNC=postgresql://carddemo:carddemo@localhost:5432/carddemo

# JWT Security — generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-min-256-bits-replace-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Application
APP_TITLE_LINE1=AWS Mainframe Cloud Demo
APP_TITLE_LINE2=Credit Card Demo Application

# bcrypt work factor (10 for dev speed, 12 for production)
BCRYPT_ROUNDS=12
