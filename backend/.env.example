# CardDemo backend environment variables
# Copy this file to .env and fill in your values

# Database — PostgreSQL (async asyncpg driver for runtime, psycopg2 for Alembic)
DATABASE_URL=postgresql+asyncpg://carddemo:carddemo@localhost:5432/carddemo
DATABASE_URL_SYNC=postgresql://carddemo:carddemo@localhost:5432/carddemo

# JWT — replace with a 256-bit random key in production
JWT_SECRET_KEY=dev-secret-key-replace-in-production-min-256-bits
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS — Next.js frontend origin
CORS_ORIGINS=["http://localhost:3000"]

# bcrypt work factor (10=dev, 12=prod)
BCRYPT_ROUNDS=12
