# CardDemo FastAPI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection URL (async driver required)
DATABASE_URL=postgresql+asyncpg://mridul:mridul12345&@localhost:5432/carddemo_4

# Enable SQLAlchemy query logging (set to False in production)
DATABASE_ECHO=False

# ── JWT Authentication ────────────────────────────────────────────────────────
# Secret key for signing JWT tokens.
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: Change this before deploying to any non-local environment.
SECRET_KEY=carddemo-secret-key-change-in-production-minimum-32-chars

# JWT signing algorithm
ALGORITHM=HS256

# Token expiry in minutes (480 = 8 hours, equivalent to a mainframe shift)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Application Identity ──────────────────────────────────────────────────────
# These map to CICS COTTL01Y system constants
APP_TITLE=AWS Mainframe Modernization - CardDemo API
APP_VERSION=1.0.0
APP_APPLID=CARDDEMO
APP_SYSID=CD01

# ── Pagination Defaults ───────────────────────────────────────────────────────
# COTRN00C: 10 rows per page
DEFAULT_PAGE_SIZE=10
# COCRDLIC: 7 rows per page
CARD_LIST_PAGE_SIZE=7
# COUSR00C: 10 rows per page
USER_LIST_PAGE_SIZE=10
# COTRTLIC: 7 rows per page
TRAN_TYPE_LIST_PAGE_SIZE=7

# ── Batch Processing ──────────────────────────────────────────────────────────
# COPAUA0C processes max 500 auth messages per invocation
AUTH_BATCH_LIMIT=500

# CBACT04C: monthly interest = balance * rate / 12
INTEREST_CALC_DIVISOR=12
