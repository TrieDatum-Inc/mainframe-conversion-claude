# CardDemo API Environment Configuration
# Copy to .env and adjust for your environment

# Application
APP_NAME="CardDemo API"
ENVIRONMENT=development
DEBUG=false

# Database (async URL for SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://mridul:mridul12345&@localhost:5432/carddemo_3
DATABASE_URL_SYNC=postgresql+psycopg2://mridul:mridul12345&@localhost:5432/carddemo_3
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# JWT Security — CHANGE IN PRODUCTION
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-32-PLUS-CHAR-SECRET-KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
