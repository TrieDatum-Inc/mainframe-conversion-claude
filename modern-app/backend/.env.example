# Copy this file to .env and fill in values before running locally

DATABASE_URL=postgresql+asyncpg://carddemo:carddemo@localhost:5432/carddemo

# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string-at-least-32-chars

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000"]

DEBUG=false
